# MapMyTrain Environment Variables
# Copy this file to .env and fill in production values

# === Database ===
POSTGRES_USER=mmt_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=mapmytrain
DB_PORT=5432

# === Redis ===
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_PORT=6379

# === Backend ===
DEVELOPMENT_MOCK_MODE=false
INGESTION_INTERVAL_SECONDS=120
BACKEND_PORT=8000
CORS_ORIGINS=https://mapmytrain.com,https://www.mapmytrain.com

# === Frontend ===
NEXT_PUBLIC_BACKEND_WS_URL=wss://api.mapmytrain.com/api/v1/stream
NEXT_PUBLIC_TILE_SERVER_URL=https://tiles.mapmytrain.com
NEXT_PUBLIC_USE_MOCK_TELEMETRY=false
FRONTEND_PORT=3000

# === Tile Server (optional) ===
TILESERVER_PORT=8080
